<?xml version="1.0"?>
<launch>

  <!-- Path to the robot's xacro file (generated by MoveIt Setup Assistant) -->
  <let name="urdf_xacro"
       value="$(find-pkg-share athens_moveit_config)/config/athens.urdf.xacro" />

  <!-- robot_state_publisher: loads URDF, publishes /robot_description and /tf -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
    <param name="robot_description"
           value="$(command 'xacro $(var urdf_xacro)')"
           type="str" />
    <param name="use_sim_time" value="true" />
  </node>

  <!-- gz_spawn_model: spawns the robot into Gazebo by reading /robot_description topic -->
  <node pkg="ros_gz_sim" exec="create" name="gz_spawn_model"
        args="-topic /robot_description -name athens -z 0.1">
    <param name="use_sim_time" value="true" />
  </node>

  <!-- Spawner for joint_state_broadcaster controller -->
  <node pkg="controller_manager" exec="spawner" name="spawner_joint_state_broadcaster"
        args="joint_state_broadcaster -c /controller_manager">
    <param name="use_sim_time" value="true" />
  </node>

  <node pkg="rviz2" exec="rviz2" name="rviz2"
      args="-d $(find-pkg-share athens_gazebo)/config/gazebo.rviz">
  <param name="use_sim_time" value="true" />
</node>

</launch>
